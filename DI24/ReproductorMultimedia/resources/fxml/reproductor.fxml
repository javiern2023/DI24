<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="app.ReproductorController">

    <Label fx:id="lblEstado" text="Cargando..." />

    <Slider fx:id="sliderProgreso" prefWidth="300" />

    <HBox spacing="10" alignment="CENTER">
        <Button text="Play" onAction="#play" />
        <Button text="Pause" onAction="#pause" />
        <Button text="Stop" onAction="#stop" />
    </HBox>

    <Label text="Volumen:" />
    <Slider fx:id="sliderVolumen" prefWidth="150" />

</VBox>

